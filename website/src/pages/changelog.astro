---
import LandingLayout from '../layouts/LandingLayout.astro';
// CHANGELOG.md lives at the website root (synced from the repo root by the
// prebuild/predev scripts) and is inlined statically via a Vite ?raw import.
// Keeping it inside website/ lets deploy environments like Dokploy/nixpacks —
// which use website/ as the build context — still find the file.
import changelogRaw from '../../CHANGELOG.md?raw';

type BulletNode = {
  text: string;       // already-rendered HTML (bold, code, links)
  children: BulletNode[];
};

type ReleaseEntry = {
  version: string;
  date: string | null;
  bullets: BulletNode[];
};

// Render inline markdown: **bold**, `code`, [text](url)
// Note: use the character classes [<] / [>] instead of bare < / > so esbuild
// doesn't mistake the RegExp literals for JSX tag open/close in the frontmatter.
function renderInline(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/[<]/g, '&lt;')
    .replace(/[>]/g, '&gt;')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
}

// Parse CHANGELOG.md
function parseChangelog(raw: string): ReleaseEntry[] {
  const lines = raw.split('\n');
  const releases: ReleaseEntry[] = [];
  let current: ReleaseEntry | null = null;
  let bulletStack: BulletNode[][] = [];

  for (const line of lines) {
    if (!line.trim() || /^\[[^\]]+\]:\s/.test(line)) continue;

    const h2 = line.match(/^##\s+\[([^\]]+)\](?:\s*[—-]\s*(.+))?\s*$/);
    if (h2) {
      current = { version: h2[1], date: (h2[2] || '').trim() || null, bullets: [] };
      releases.push(current);
      bulletStack = [current.bullets];
      continue;
    }

    const bullet = line.match(/^(\s*)-\s+(.+)$/);
    if (bullet && current) {
      const indent = bullet[1].length;
      const level = Math.floor(indent / 2);
      const node: BulletNode = { text: renderInline(bullet[2]), children: [] };

      while (bulletStack.length > level + 1) bulletStack.pop();
      if (bulletStack.length <= level) {
        const parent = bulletStack[bulletStack.length - 1];
        const last = parent[parent.length - 1];
        if (last) bulletStack.push(last.children);
      }
      bulletStack[bulletStack.length - 1].push(node);
      continue;
    }

    if (current && line.trim()) {
      current.bullets.push({ text: renderInline(line.trim()), children: [] });
    }
  }

  return releases;
}

function renderBullets(bullets: BulletNode[]): string {
  if (!bullets.length) return '';
  const inner = bullets.map((b) => '<li>' + b.text + renderBullets(b.children) + '</li>').join('');
  return '<ul>' + inner + '</ul>';
}

const releases = parseChangelog(changelogRaw);
---
<LandingLayout
  title="Zap · Changelog"
  description="Feature updates and changes across Zap releases"
>
  <main class="changelog-shell">
    <header class="changelog-hero wrap">
      <div class="feat-eyebrow">
        <span>CHANGELOG</span>
      </div>
      <h1>Changelog</h1>
      <p class="lede">Notable changes shipped across Zap preview and OSS releases. Sourced from <code>CHANGELOG.md</code> in the repo.</p>
    </header>

    <div class="changelog-wrap wrap">
      {releases.map((r) => (
        <article class="cl-entry">
          <aside class="cl-meta">
            {r.date && <div class="cl-date">{r.date}</div>}
            <div class="cl-version">
              <span class="cl-dot"></span>
              {r.version}
            </div>
          </aside>
          <div class="cl-body">
            <h2 class="cl-title">{r.version}</h2>
            <div class="cl-content" set:html={renderBullets(r.bullets)}></div>
          </div>
        </article>
      ))}
    </div>

    <div class="changelog-foot wrap">
      <p class="muted">Looking for the full git history? Browse the <a href="https://github.com/zerx-lab/zap/commits/main" target="_blank" rel="noopener">commits on GitHub</a>.</p>
    </div>
  </main>
</LandingLayout>

<style is:global>
  /* Changelog page: Cursor-style timeline layout */
  .changelog-shell { padding: 64px 0 80px; }

  .changelog-hero { max-width: 880px; padding-top: 24px; padding-bottom: 48px; border-bottom: 1px solid var(--line); margin-bottom: 56px; }
  .changelog-hero h1 {
    font-family: "Inter Tight", system-ui, sans-serif;
    font-size: clamp(34px, 4.5vw, 48px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 14px 0 16px;
    color: var(--ink);
  }
  .changelog-hero .lede {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }
  .changelog-hero .lede code {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 13px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    padding: 1px 6px;
    border-radius: 4px;
    color: var(--ink);
  }

  .changelog-wrap { max-width: 880px; }

  .cl-entry {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 32px;
    padding-bottom: 56px;
    margin-bottom: 56px;
    border-bottom: 1px solid var(--line);
  }
  .cl-entry:last-of-type { border-bottom: 0; margin-bottom: 0; padding-bottom: 0; }
  @media (max-width: 760px) {
    .cl-entry { grid-template-columns: 1fr; gap: 12px; padding-bottom: 40px; margin-bottom: 40px; }
  }

  .cl-meta {
    position: sticky;
    top: 84px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  @media (max-width: 760px) {
    .cl-meta { position: static; flex-direction: row; align-items: center; gap: 12px; }
  }
  .cl-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .cl-version {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--ink-2);
    padding: 3px 9px 3px 7px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    align-self: flex-start;
    word-break: break-all;
    max-width: 100%;
  }
  .cl-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
    flex-shrink: 0;
  }

  .cl-body { min-width: 0; }
  .cl-title {
    font-family: "Inter Tight", system-ui, sans-serif;
    font-size: 24px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0 0 16px;
    color: var(--ink);
    word-break: break-word;
  }
  @media (max-width: 760px) {
    .cl-title { font-size: 21px; }
  }

  .cl-content { color: var(--ink-2); font-size: 14.5px; line-height: 1.7; }
  .cl-content ul { padding-left: 20px; margin: 0 0 12px; }
  .cl-content ul ul { margin: 4px 0 6px; }
  .cl-content li { margin: 6px 0; }
  .cl-content li::marker { color: var(--muted-2); }
  .cl-content strong { color: var(--ink); font-weight: 600; }
  .cl-content code {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12.5px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    padding: 1px 6px;
    border-radius: 4px;
    color: var(--ink);
  }
  .cl-content a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }
  .cl-content a:hover { border-bottom-color: var(--accent-line); }

  .changelog-foot { max-width: 880px; padding-top: 32px; border-top: 1px solid var(--line); margin-top: 24px; }
  .changelog-foot .muted { font-size: 13px; color: var(--muted); margin: 0; }
  .changelog-foot a { color: var(--accent); border-bottom: 1px solid transparent; transition: border-color 0.15s ease; }
  .changelog-foot a:hover { border-bottom-color: var(--accent-line); }
</style>
