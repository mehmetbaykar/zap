---
import LandingLayout from '../layouts/LandingLayout.astro';

const repo = 'https://github.com/mehmetbaykar/zap';

// Centralized copy.
const t = {
  hero: {
    badge: 'v0 · OSS preview',
    h1a: 'The terminal,',
    h1b: 'rebuilt around you.',
    lede: 'Zap is a derivative product built on Warp — a fully open, local-first take on the agentic terminal. Every credential, conversation and key stays on your machine. Bring your own provider, your own keys, your own rules.',
    primary: 'Install Zap',
    secondary: 'View on GitHub',
  },
  logos: {
    title: 'Native protocols — bring any provider',
  },
  feat1: {
    eyebrow: 'TERMINAL',
    h: 'A real terminal, with an AI you actually own.',
    p: 'Every Block — cwd, env, exit code — feeds an AI conversation you can swap, replay or kill at any time. No telemetry, no remote calls, no hidden cloud.',
    more: 'Read the docs →',
  },
  feat2: {
    eyebrow: 'PROVIDERS',
    h: 'Six native protocols. Hundreds of presets. Your keys.',
    p: 'Pick from a directory of 250+ providers — OpenAI-compatible, Anthropic, Gemini, Ollama, DeepSeek, OpenAI-Response — or wire your own endpoint in one paste. Keys live in the OS keychain.',
    more: 'See provider list →',
  },
  feat3: {
    eyebrow: 'LOCALIZED',
    h: 'Localized end-to-end. Not just labels.',
    p: 'Settings, prompts, command palette, telemetry banners — all rewritten in multiple languages. Switch any time; preference persists locally.',
    more: 'Switch language ↑',
  },
  quote: {
    text: 'The terminal was always a local tool. Zap keeps it that way — even when the AI joins.',
    cite: 'Project ethos',
  },
  install: {
    eyebrow: 'INSTALL',
    h: 'Build it yourself in two commands.',
    p: 'No installer in preview — Zap is source-available and ships only as a build script. Clone, bootstrap, run.',
    tabMac: 'macOS', tabLinux: 'Linux', tabWin: 'Windows',
  },
  cta: {
    h: 'Your terminal. Your keys.',
    p: 'Source-available · Self-hostable · Built with Rust',
    primary: 'Quickstart',
    secondary: 'Read the changelog',
  },
};

// Provider examples (for the chip-grid in mock 2)
const providerChips = ['302.AI (97)', 'Abacus (65)', 'abliteration.ai (1)', 'AIHubMix (50)', 'Alibaba (48)', 'Alibaba (China) (80)', 'Alibaba Coding (9)', 'Together (16)'];

// Logos (trust wall) — we have no real partners, so we use the names of natively supported protocols.
const protocols = ['OpenAI', 'Anthropic', 'Gemini', 'Ollama', 'DeepSeek', 'OpenAI-Response'];
---
<LandingLayout>
  <!-- ============== HERO ============== -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="fade-in">
        <span class="hero-badge"><span class="pulse-dot"></span>
          <span>{t.hero.badge}</span>
        </span>
        <h1>
          <span>{t.hero.h1a}<br/><span class="em">{t.hero.h1b}</span></span>
        </h1>
        <p class="lede">{t.hero.lede}</p>
        <div class="hero-cta">
          <a class="btn" href="#install">
            <span>{t.hero.primary}</span>
            <span class="arr">→</span>
          </a>
          <a class="btn alt" href={repo} target="_blank" rel="noopener">
            <span>{t.hero.secondary}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Below the hero: simulated terminal window (full width, hint card on the left, terminal on the right) -->
    <div class="wrap">
      <div class="hero-art fade-in delay-1" aria-hidden="true">
        <div class="app-window mock-terminal hero-window">
          <div class="app-titlebar">
            <div class="tb-icon" title="sidebar">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg>
            </div>
            <div class="app-tabs">
              <div class="app-tab active"><span>~ - fish</span></div>
              <div class="app-tab add">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="width:9px;height:9px;opacity:.6"><path d="M3 4l3 4 3-4"/></svg>
              </div>
            </div>
            <div class="app-controls">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 9l5-5 5 5M8 4v9"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2.5" y="3" width="11" height="8" rx="1"/><path d="M2.5 7h11"/></svg></div>
              <button class="tb-icon tb-theme" type="button" data-theme-toggle title="Toggle theme" aria-label="Toggle color theme">
                <svg class="tb-theme-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <g class="tb-sun">
                    <circle cx="8" cy="8" r="3"/>
                    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.2 3.2l1.4 1.4M11.4 11.4l1.4 1.4M3.2 12.8l1.4-1.4M11.4 4.6l1.4-1.4"/>
                  </g>
                  <path class="tb-moon" d="M14 9.5A6 6 0 1 1 6.5 2a5 5 0 0 0 7.5 7.5z"/>
                </svg>
              </button>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 8h10"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="10" height="10" rx="1"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 4l8 8M12 4l-8 8"/></svg></div>
            </div>
          </div>
          <div class="app-body">
            <!-- Left: keyboard-shortcut hint card + status bar -->
            <div class="hero-side">
              <div class="hero-hint">
                <div class="hh-title">
                  <svg class="ico" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11l4-4 4 4M3 7l4-4 4 4"/></svg>
                  <span>New terminal session</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">ctrl</span><span class="kbd">shift</span><span class="kbd">↩</span></span>
                  <span>New Agent chat</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">↑</span></span>
                  <span>History</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">⌘</span><span class="kbd">K</span></span>
                  <span>Command palette</span>
                </div>
              </div>
              <div class="hero-status">
                <span class="ok">anthropic / claude-4-7</span>
                <span>local · no telemetry</span>
              </div>
            </div>

            <!-- Right: terminal output + executable input -->
            <div class="hero-main">
              <div class="term-stage"></div>
              <div class="term-input live">
                <div class="ti-fakeshell">
                  <span class="ps1">~ $</span>
                  <input
                    id="hero-shell-input"
                    type="text"
                    autocomplete="off"
                    spellcheck="false"
                    placeholder="Try: help, ls, agent fix the linker error, provider list"
                  />
                </div>
                <div class="ti-help">
                  <span>Type <code>help</code> for commands · <code>↑</code>/<code>↓</code> history · <code>clear</code> reset</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== LOGOS / PROTOCOLS ============== -->
  <div class="logos fade-in">
    <p class="logos-title">
      <span>{t.logos.title}</span>
    </p>
    <div class="logos-track">
      {protocols.map((p) => <span class="item">{p}</span>)}
    </div>
  </div>

  <!-- ============== FEAT 1: Terminal ============== -->
  <section class="section" id="how">
    <div class="wrap">
      <article class="feat-card fade-in">
        <div class="feat-text">
          <div class="feat-eyebrow">
            <span>{t.feat1.eyebrow}</span>
          </div>
          <h3>{t.feat1.h}</h3>
          <p>{t.feat1.p}</p>
          <a class="more" href="/docs/quickstart">
            <span>{t.feat1.more}</span>
          </a>
        </div>
        <div class="feat-vis">
          <div class="app-window mock-terminal" style="min-height:340px">
            <div class="app-titlebar">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg></div>
              <div class="app-tabs">
                <div class="app-tab active">~/zap - fish</div>
                <div class="app-tab add">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                </div>
              </div>
            </div>
            <div class="app-body">
              <div class="term-stage">
                <div class="typing-line"><span class="p">$</span> cargo build --release</div>
                <div class="typing-line dim">   Compiling zap v0.1.0</div>
                <div class="typing-line dim">   Compiling warp_terminal v0.1.0</div>
                <div class="typing-line"><span class="ok">✓</span> <span class="dim">Finished in 12.4s</span></div>
              </div>
              <div class="term-input" style="margin-top:auto">
                <span class="ti-chip">block · cwd · env · exit</span>
                <div class="ti-prompt">▌ Why did the linker fail on this target?</div>
                <div class="ti-meta">
                  <span style="font-family: 'JetBrains Mono', monospace; color: var(--accent)">/agent</span>
                  <span>Anthropic · claude-opus-4-7</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============== FEAT 2: Providers (reverse layout) ============== -->
  <section class="section" id="adapt">
    <div class="wrap">
      <article class="feat-card reverse fade-in">
        <div class="feat-text">
          <div class="feat-eyebrow">
            <span>{t.feat2.eyebrow}</span>
          </div>
          <h3>{t.feat2.h}</h3>
          <p>{t.feat2.p}</p>
          <a class="more" href={repo} target="_blank" rel="noopener">
            <span>{t.feat2.more}</span>
          </a>
        </div>
        <div class="feat-vis">
          <div class="app-window mock-settings">
            <div class="app-titlebar">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg></div>
              <div class="app-tabs">
                <div class="app-tab">~ - fish</div>
                <div class="app-tab active">
                  <span>Settings</span>
                </div>
                <div class="app-tab add">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                </div>
              </div>
            </div>
            <div class="app-body">
              <!-- Left sidebar -->
              <div class="set-sidebar">
                <div class="ss-search">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="7" cy="7" r="4.5"/><path d="M14 14l-3.5-3.5"/></svg>
                  <span>Search</span>
                </div>
                <div class="ss-group">
                  <span>Agents</span><span class="chev">▾</span>
                </div>
                <a class="ss-item">Zap agent</a>
                <a class="ss-item">Config</a>
                <a class="ss-item active">Providers</a>
                <a class="ss-item">MCP servers</a>
                <a class="ss-item">Rules</a>
                <a class="ss-top muted">Code</a>
                <a class="ss-top muted">Appearance</a>
                <a class="ss-top muted">Features</a>
              </div>

              <!-- Right content -->
              <div class="set-content">
                <div class="sc-head">
                  <h4 class="sc-h3">
                    <span>Agent providers</span>
                  </h4>
                  <button class="sc-add" type="button">+ <span>Add</span></button>
                </div>
                <p class="sc-desc">
                  <span>Configure any OpenAI-compatible / Anthropic / Gemini / Ollama / DeepSeek endpoint. Keys are stored in the OS keychain.</span>
                </p>

                <div class="sc-quickadd">
                  <div class="qa-head">
                    <span>Quick add</span>
                    <span class="qa-search">Search providers…</span>
                  </div>
                  <div class="chip-grid">
                    {providerChips.map((p) => (
                      <span class="pchip"><span class="plus">+</span>{p}</span>
                    ))}
                    <span class="pchip more">+ 247 more ▾</span>
                  </div>
                </div>

                <div class="set-form">
                  <div class="sf-row">
                    <div class="sf-label">
                      <span>Name</span>
                    </div>
                    <div class="sf-val">Anthropic</div>
                  </div>
                  <div class="sf-row">
                    <div class="sf-label">API <span>protocol</span></div>
                    <div class="sf-protocols">
                      <span class="ptab">OpenAI</span>
                      <span class="ptab">OpenAI-Response</span>
                      <span class="ptab">Gemini</span>
                      <span class="ptab active">Anthropic</span>
                      <span class="ptab">Ollama</span>
                      <span class="ptab">DeepSeek</span>
                    </div>
                  </div>
                  <div class="sf-actions">
                    <button class="sf-btn" type="button">+ Add model</button>
                    <button class="sf-btn primary" type="button">Save</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============== FEAT 3: Localization ============== -->
  <section class="section" id="privacy">
    <div class="wrap">
      <article class="feat-card fade-in">
        <div class="feat-text">
          <div class="feat-eyebrow">
            <span>{t.feat3.eyebrow}</span>
          </div>
          <h3>{t.feat3.h}</h3>
          <p>{t.feat3.p}</p>
        </div>
        <div class="feat-vis">
          <div class="app-window mock-language">
            <div class="app-titlebar">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg></div>
              <div class="app-tabs">
                <div class="app-tab active">
                  <span>Settings · Appearance</span>
                </div>
                <div class="app-tab add">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                </div>
              </div>
            </div>
            <div class="app-body">
              <div class="lang-block">
                <div class="lb-h">Language</div>
                <div class="lb-row">
                  <div class="lb-text">
                    <div class="t">Language</div>
                    <div class="d">Restart Zap to fully apply this change.</div>
                  </div>
                  <div class="lb-select" id="hero-lang-select">
                    <span class="lb-current">System default</span>
                    <div class="lang-dropdown">
                      <button class="ldi" type="button">
                        <span>System default</span>
                      </button>
                      <button class="ldi" type="button">English</button>
                    </div>
                  </div>
                </div>
              </div>
              <div class="lang-block">
                <div class="lb-h">Window</div>
                <div class="lb-row">
                  <div class="lb-text">
                    <div class="t">Window opacity: 100</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============== QUOTE (single) ============== -->
  <section class="quote fade-in">
    <div class="wrap">
      <blockquote>{t.quote.text}</blockquote>
      <div class="cite">
        — <span>{t.quote.cite}</span>
      </div>
    </div>
  </section>

  <!-- ============== INSTALL ============== -->
  <section class="section" id="install">
    <div class="wrap">
      <div class="fade-in" style="max-width: 720px;">
        <div class="feat-eyebrow">
          <span>{t.install.eyebrow}</span>
        </div>
        <h2 class="sec-h2">{t.install.h}</h2>
        <p class="sec-lede">{t.install.p}</p>
      </div>

      <div class="install-card fade-in delay-1">
        <div class="install-tabs">
          <button data-tab="macos" class="active">macOS</button>
          <button data-tab="linux">Linux</button>
          <button data-tab="windows">Windows<span class="meta">.ps1</span></button>
        </div>

        <div class="pre-wrap" data-pane="macos">
          <pre class="code"><span class="com"># 1. Bootstrap dependencies (Xcode CLT + cargo helpers)</span>
git clone https://github.com/mehmetbaykar/zap.git zap
<span class="key">cd</span> zap
./script/bootstrap

<span class="com"># 2. Build &amp; run</span>
./script/run --release</pre>
          <button class="copy" type="button" data-copy>Copy</button>
        </div>

        <div class="pre-wrap" data-pane="linux" hidden>
          <pre class="code"><span class="com"># Debian / Ubuntu (apt + cargo)</span>
git clone https://github.com/mehmetbaykar/zap.git zap
<span class="key">cd</span> zap
./script/bootstrap

<span class="com"># Build &amp; run</span>
./script/run --release</pre>
          <button class="copy" type="button" data-copy>Copy</button>
        </div>

        <div class="pre-wrap" data-pane="windows" hidden>
          <pre class="code"><span class="com"># Run from PowerShell (winget + rustup)</span>
git clone https://github.com/mehmetbaykar/zap.git zap
<span class="key">cd</span> zap
./script/bootstrap

<span class="com"># Build &amp; run</span>
./script/run --release</pre>
          <button class="copy" type="button" data-copy>Copy</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== CTA ============== -->
  <section class="cta-band">
    <div class="wrap fade-in">
      <h2>
        <span>{t.cta.h}</span>
      </h2>
      <p>{t.cta.p}</p>
      <div class="btn-row">
        <a class="btn" href="/docs/quickstart">
          <span>{t.cta.primary}</span>
          <span class="arr">→</span>
        </a>
        <a class="btn alt" href="/changelog">
          <span>{t.cta.secondary}</span>
        </a>
      </div>
    </div>
  </section>
</LandingLayout>

<script>
  // ============================================================
  // Hero simulated terminal: an executable fake shell
  // - A few preset commands (help / ls / pwd / clear / agent / provider / theme / whoami / echo)
  // - Up/Down arrows walk the history
  // ============================================================
  (function () {
    const stage = document.querySelector('.hero-art .term-stage') as HTMLElement | null;
    if (!stage) return;

    // Initial animated lines (shown right after the page loads)
    const initLines: string[] = [
      `<span class="p">$</span> npm run build`,
      `<span class="dim">› vite v5.4 · production</span>`,
      `<span class="dim">› 248 modules transformed</span>`,
      `<span class="ok">✓ built in 1.24s</span>`,
    ];
    function renderInitLines() {
      stage.innerHTML = initLines
        .map((l) => `<div class="typing-line">${l}</div>`)
        .join('');
    }

    // Render the initial animated lines
    renderInitLines();

    const inputs = Array.from(document.querySelectorAll<HTMLInputElement>('.ti-fakeshell input'));
    if (!inputs.length) return;
    const history: string[] = [];
    let histIdx = -1;

    function escape(s: string) {
      return s.replace(/&/g, '&amp;').replace(/[<]/g, '&lt;').replace(/[>]/g, '&gt;');
    }
    function printRaw(html: string, cls = '') {
      const div = document.createElement('div');
      div.className = 'out-line' + (cls ? ' ' + cls : '');
      div.innerHTML = html;
      stage.appendChild(div);
      stage.scrollTop = stage.scrollHeight;
    }
    function printLines(lines: string[], cls = '') {
      lines.forEach((l, i) => {
        setTimeout(() => printRaw(l, cls), i * 60);
      });
    }

    // Command response tables
    const responses: Record<string, string[]> = {
      help: [
        'Available commands:',
        '  help               show this list',
        '  ls                 list current directory',
        '  pwd                print working directory',
        '  whoami             print current user',
        '  echo &lt;text&gt;        print text back',
        '  agent &lt;prompt&gt;     send a prompt to the local AI agent',
        '  provider list      list configured AI providers',
        '  theme              toggle dark / light',
        '  clear              clear the screen',
      ],
      ls: ['Cargo.toml  CHANGELOG.md  README.md  app/  crates/  docs/  scripts/  website/'],
      pwd: ['/home/you/zap'],
      whoami: ['you'],
      providerList: [
        '<span class="k">PROTOCOL</span>           <span class="k">NAME</span>          <span class="k">STATUS</span>',
        'openai            anthropic     <span class="s">ready</span>',
        'anthropic         claude-4-7    <span class="s">ready</span>',
        'deepseek          deepseek-v4   <span class="s">ready</span>',
        'ollama            local         <span class="s">ready</span>',
      ],
    };

    function agentResponse(prompt: string): string[] {
      const cleaned = prompt.trim() || 'no prompt';
      return [
        `<span class="k">[agent]</span> <span class="dim">routing to</span> anthropic/claude-4-7`,
        `<span class="k">[agent]</span> <span class="dim">prompt</span>: ${escape(cleaned)}`,
        `<span class="dim">thinking...</span>`,
        `<span class="s">→</span> This is a simulated response. In real Zap this would call your configured provider locally.`,
        `<span class="dim">Credentials, conversation and context all stay on your machine.</span>`,
      ];
    }

    function run(raw: string) {
      const cmd = raw.trim();
      if (!cmd) return;
      history.push(cmd);
      histIdx = history.length;

      // Echo the command
      printRaw(`<span class="p">$</span> ${escape(cmd)}`);

      const lower = cmd.toLowerCase();
      const head = cmd.split(/\s+/)[0].toLowerCase();
      const rest = cmd.slice(head.length).trim();

      if (lower === 'clear' || lower === 'cls') {
        setTimeout(() => { stage.innerHTML = ''; }, 80);
        return;
      }
      if (head === 'help') { printLines(responses.help, 'dim'); return; }
      if (head === 'ls')   { printLines(responses.ls); return; }
      if (head === 'pwd')  { printLines(responses.pwd); return; }
      if (head === 'whoami') { printLines(responses.whoami); return; }
      if (head === 'echo') { printRaw(escape(rest)); return; }
      if (head === 'theme') {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('zap:theme', next); } catch (_) {}
        printRaw(`Theme switched to ${next}`, 'ok');
        return;
      }
      if (head === 'provider' && rest === 'list') {
        printLines(responses.providerList);
        return;
      }
      if (head === 'agent') { printLines(agentResponse(rest)); return; }

      // Unknown command
      printRaw(`zap: command not found: ${escape(head)}. Type <span class="s">help</span> to list commands.`, 'err');
    }

    inputs.forEach((input) => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const val = input.value;
          input.value = '';
          run(val);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (history.length === 0) return;
          histIdx = Math.max(0, histIdx - 1);
          input.value = history[histIdx] || '';
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (histIdx < history.length - 1) {
            histIdx += 1;
            input.value = history[histIdx] || '';
          } else {
            histIdx = history.length;
            input.value = '';
          }
        }
      });
    });
  })();
</script>
