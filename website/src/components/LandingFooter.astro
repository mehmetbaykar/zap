---
const repo = 'https://github.com/zerx-lab/zap';
---
<div class="footer-logo">
  <div class="wrap">
    <div class="foot-cols">
      <div>
        <h4>Zap</h4>
        <p style="font-size: 13px; color: var(--muted); line-height: 1.6; margin: 0;">
          <span>A derivative product built on Warp. Bring any AI model into your terminal — locally.</span>
        </p>
      </div>
      <div>
        <h4>PRODUCT</h4>
        <a href="/#how">How it works</a>
        <a href="/#install">Install</a>
        <a href="/#privacy">Privacy</a>
        <a href="/docs/quickstart">Docs</a>
      </div>
      <div>
        <h4>COMMUNITY</h4>
        <a href={repo} target="_blank" rel="noopener">GitHub</a>
        <a href={`${repo}/issues`} target="_blank" rel="noopener">Issues</a>
        <a href={`${repo}/discussions`} target="_blank" rel="noopener">Discussions</a>
        <a href="/changelog">Changelog</a>
      </div>
      <div>
        <h4>UPSTREAM</h4>
        <a href="https://github.com/warpdotdev/warp" target="_blank" rel="noopener">warpdotdev/warp</a>
        <a href="https://github.com/sst/opencode" target="_blank" rel="noopener">opencode-ai/opencode</a>
        <a href="https://models.dev" target="_blank" rel="noopener">models.dev</a>
      </div>
    </div>

    <p class="ow-mono"><span>Zap</span><span class="dot">.</span></p>

    <footer class="foot wrap" style="padding-left:0; padding-right:0">
      <div class="foot-bottom">
        <span>© 2026 Zap · <span>built on Warp</span></span>
        <span>Made with Rust · Source-available</span>
      </div>
      <p class="disclaimer">
        <span>Zap is an independent derivative product built on Warp. It is not produced, endorsed, sponsored, or supported by Warp Inc. "Warp" and the Warp logo are trademarks of Warp Inc.; references to them on this site are descriptive and indicate the upstream project this product is built on.</span>
      </p>
    </footer>
  </div>
</div>
