---
import GhIcon from './GhIcon.astro';
import ThemeToggle from './ThemeToggle.astro';
const repo = 'https://github.com/zerx-lab/zap';
---
<header class="nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <img class="brand-logo" src="/logo.svg" alt="Zap" width="26" height="26" />
      Zap
    </a>
    <nav class="nav-links" id="primary-nav">
      <a href="#how">Terminal</a>
      <a href="#adapt">Providers</a>
      <a href="/docs/quickstart">Docs</a>
      <a href="/changelog">Changelog</a>
    </nav>
    <div class="nav-spacer"></div>
    <div class="nav-right">
      <ThemeToggle />
      <a class="gh" href={repo} target="_blank" rel="noopener">
        <GhIcon />
        <span>GitHub</span>
      </a>
      <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-controls="primary-nav" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>
