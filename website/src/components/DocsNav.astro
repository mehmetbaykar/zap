---
import GhIcon from './GhIcon.astro';
import ThemeToggle from './ThemeToggle.astro';
const repo = 'https://github.com/zerx-lab/zap';
---
<header class="nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <img class="brand-logo" src="/logo.svg" alt="Zap" width="26" height="26" />
      Zap
    </a>
    <nav class="nav-links">
      <a href="/">README</a>
      <a href="/docs/quickstart" class="active">Docs</a>
      <a href={repo} target="_blank" rel="noopener">Providers</a>
      <a href="/changelog">Changelog</a>
    </nav>
    <div class="nav-spacer"></div>
    <div class="nav-right">
      <ThemeToggle />
      <a class="gh-link" href={repo} target="_blank" rel="noopener">
        <GhIcon /><span>GitHub</span>
      </a>
    </div>
  </div>
</header>
