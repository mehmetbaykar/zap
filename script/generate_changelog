#!/usr/bin/env bash
#
# Preview Zap Release notes locally — uses the same cliff.toml as
# .github/workflows/zap_release.yml, ensuring the release body CI produces matches what you see locally.
#
# Usage:
#   script/generate_changelog                   # from the previous v* tag to HEAD, the locally-unreleased section
#   script/generate_changelog v2026.05.27.2     # specify the tag about to be released
#   script/generate_changelog v2026.05.27.2 v2026.05.06.preview
#                                               # specify the previous tag explicitly, skipping git describe
#
# Output goes to stdout; to save it, do `... > preview.md` yourself.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

if ! command -v git-cliff >/dev/null 2>&1; then
    echo "error: git-cliff is not installed. On Arch use 'pacman -S git-cliff'; on other platforms use" >&2
    echo "       'cargo install --locked git-cliff' or 'cargo binstall git-cliff'." >&2
    exit 1
fi

THIS_TAG="${1:-HEAD}"
PREV_TAG="${2:-}"

if [[ -z "$PREV_TAG" ]]; then
    # Same strategy as in the workflow: if HEAD is a tag, search from HEAD^, otherwise search from HEAD.
    if git rev-parse "$THIS_TAG" >/dev/null 2>&1 && \
       git describe --tags --exact-match "$THIS_TAG" >/dev/null 2>&1; then
        PREV_TAG=$(git describe --tags --abbrev=0 --match='v*' "${THIS_TAG}^" 2>/dev/null || echo "")
    else
        PREV_TAG=$(git describe --tags --abbrev=0 --match='v*' HEAD 2>/dev/null || echo "")
    fi
fi

ARGS=(--config cliff.toml --strip header --tag "$THIS_TAG")
if [[ -n "$PREV_TAG" ]]; then
    ARGS+=("${PREV_TAG}..HEAD")
    echo "# preview: ${PREV_TAG} → ${THIS_TAG}" >&2
else
    echo "# preview: first release (no prev tag) → ${THIS_TAG}" >&2
fi

git-cliff "${ARGS[@]}"
